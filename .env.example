# PGChat Configuration
# Copy this to .env and fill in your values

# Database connection (or use DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Or use a single connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Backend: ollama or anthropic (default: ollama)
PGCHAT_BACKEND=ollama
PGCHAT_MODEL=qwen2.5:7b

# Anthropic (only needed if backend=anthropic)
# ANTHROPIC_API_KEY=

# Show raw tool calls in the terminal (default: false)
PGCHAT_SHOW_TOOL_CALLS=false

# Show plain-English query explanation before executing SQL (default: true)
PGCHAT_EXPLAIN_QUERIES=true

