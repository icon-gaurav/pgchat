# PGAgent Configuration
# Copy this to .env and fill in your values

# Database Connection
PGAGENT_DB_HOST=localhost
PGAGENT_DB_PORT=5432
PGAGENT_DB_DATABASE=postgres
PGAGENT_DB_USER=postgres
PGAGENT_DB_PASSWORD=your_password_here

# Alternative: Use a full DATABASE_URL (overrides individual fields above)
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# LLM Configuration
PGAGENT_MODEL=qwen2.5:7b
PGAGENT_BACKEND=ollama

# For Anthropic Claude backend (set backend to "anthropic")
# ANTHROPIC_API_KEY=sk-ant-...

# UI
# PGAGENT_SHOW_TOOL_CALLS=false

